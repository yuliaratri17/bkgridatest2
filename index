<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <meta name="theme-color" content="#0f172a" />
  <title>Alat Tes Psikologi Internal - SMK PGRI 2 Kediri</title>
  <style>
    :root{
      --bg:#f4f7fb; --surface:#fff; --surface-2:#f8fafc; --text:#0f172a; --muted:#64748b;
      --primary:#0f3a66; --primary-2:#1d4ed8; --accent:#0ea5e9; --danger:#dc2626; --success:#16a34a;
      --border:#dbe3ee; --shadow:0 10px 30px rgba(15,23,42,.08); --radius:20px;
    }
    *{box-sizing:border-box} html,body{height:100%}
    body{margin:0;font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;background:var(--bg);color:var(--text)}
    button,input,textarea,select{font:inherit} a{color:var(--primary-2);text-decoration:none}
    .bg-layer{position:fixed;inset:0;z-index:-2;background:linear-gradient(180deg,#eef4ff 0%,#f7fafc 40%,#f4f7fb 100%);background-size:cover;background-position:center;transition:background .25s ease}
    .bg-overlay{position:fixed;inset:0;z-index:-1;background:radial-gradient(circle at top right, rgba(255,255,255,.45), transparent 28%),radial-gradient(circle at bottom left, rgba(14,165,233,.08), transparent 28%);pointer-events:none}
    .app{min-height:100%;display:flex;flex-direction:column}
    .topbar{position:sticky;top:0;z-index:20;backdrop-filter:blur(12px);background:rgba(255,255,255,.82);border-bottom:1px solid rgba(219,227,238,.9)}
    .topbar-inner{max-width:1200px;margin:0 auto;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
    .brand{display:flex;align-items:center;gap:12px;min-width:0}
    .logo{width:46px;height:46px;border-radius:14px;display:grid;place-items:center;background:linear-gradient(135deg,var(--primary),#2563eb);color:#fff;box-shadow:var(--shadow);font-weight:800;overflow:hidden;flex:0 0 auto}
    .logo img{width:100%;height:100%;object-fit:cover;display:block}
    .brand h1{margin:0;font-size:clamp(16px,2vw,22px);line-height:1.2}
    .brand p{margin:2px 0 0;color:var(--muted);font-size:13px}
    .pill-row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .pill{border:1px solid var(--border);background:#fff;color:var(--text);border-radius:999px;padding:9px 14px;box-shadow:0 4px 12px rgba(15,23,42,.04);cursor:pointer;transition:.15s ease}
    .pill:hover{transform:translateY(-1px)} .pill.primary{background:var(--primary);color:#fff;border-color:transparent} .pill.ghost{background:transparent}
    .container{width:min(1200px,100%);margin:0 auto;padding:18px 16px 28px;flex:1}
    .card{background:var(--surface);border:1px solid rgba(219,227,238,.95);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px}
    .grid{display:grid;gap:16px}.cols-2{grid-template-columns:repeat(2,minmax(0,1fr))}.cols-3{grid-template-columns:repeat(3,minmax(0,1fr))}
    @media (max-width:900px){.cols-2,.cols-3{grid-template-columns:1fr}}
    .hidden{display:none !important}
    .field{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}.field label{font-size:13px;color:#334155;font-weight:700}
    .input,textarea,select{width:100%;border:1px solid var(--border);border-radius:14px;background:#fff;padding:12px 14px;color:var(--text);outline:none;transition:.15s ease}
    textarea{min-height:110px;resize:vertical}.input:focus,textarea:focus,select:focus{border-color:#93c5fd;box-shadow:0 0 0 4px rgba(59,130,246,.10)}
    .row{display:flex;gap:10px;flex-wrap:wrap}.row>*{flex:1 1 180px}
    .btn{border:none;border-radius:14px;padding:12px 16px;cursor:pointer;transition:.15s ease;font-weight:700;display:inline-flex;align-items:center;justify-content:center;gap:8px}
    .btn:hover{transform:translateY(-1px)} .btn.primary{background:var(--primary);color:#fff} .btn.blue{background:var(--primary-2);color:#fff}
    .btn.gray{background:#e2e8f0;color:#0f172a} .btn.success{background:var(--success);color:#fff} .btn.danger{background:var(--danger);color:#fff}
    .btn.outline{background:#fff;border:1px solid var(--border);color:#0f172a} .btn.small{padding:9px 12px;border-radius:12px;font-size:14px}
    .section-title{display:flex;align-items:center;justify-content:space-between;gap:10px;margin:0 0 12px}.section-title h3{margin:0;font-size:18px}.section-title small{color:var(--muted)}
    .badge{display:inline-flex;align-items:center;gap:8px;background:#eff6ff;color:#1d4ed8;border:1px solid #dbeafe;padding:8px 12px;border-radius:999px;font-size:13px;margin-right:8px;margin-bottom:8px}
    
    /* Hero & Home Updates */
    .hero{display:grid;grid-template-columns:1fr;gap:16px;align-items:stretch;margin-bottom:16px}
    .hero-banner{background:linear-gradient(135deg,#0f172a,#1d4ed8 55%, #0ea5e9);color:#fff;border-radius:24px;padding:36px 26px;box-shadow:var(--shadow);position:relative;overflow:hidden;min-height:230px;border:1px solid rgba(255,255,255,.12);text-align:center;}
    .hero-banner::after{content:"";position:absolute;right:-60px;top:-70px;width:240px;height:240px;border-radius:50%;background:rgba(255,255,255,.08)}
    .hero-banner h2{font-size:clamp(28px,4vw,46px);margin:0 auto 16px;line-height:1.1; max-width: 800px;}
    .hero-banner p{color:rgba(255,255,255,.92);margin:0 auto 24px;max-width:68ch;line-height:1.7}
    .hero-meta{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;}
    .meta-badge{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);color:#fff;padding:8px 12px;border-radius:999px;font-size:13px}
    .search-card{background:rgba(255,255,255,.88);border:1px solid rgba(219,227,238,.95);border-radius:24px;padding:30px;box-shadow:var(--shadow);text-align:center;}
    .search-card h3{margin:0 0 12px;font-size:24px}.search-card p{margin:0 auto 24px;color:var(--muted);line-height:1.6; max-width: 500px;}
    
    /* Form Customization */
    .form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-bottom:24px;}
    .form-group-title{font-size:16px;font-weight:700;border-bottom:2px solid var(--border);padding-bottom:8px;margin:32px 0 16px;color:var(--primary);}
    .radio-card{border:1px solid var(--border);border-radius:14px;padding:14px;display:flex;gap:12px;align-items:flex-start;cursor:pointer;transition:.2s ease;background:var(--surface-2);margin-bottom:10px;}
    .radio-card:hover{border-color:var(--accent);background:#eff6ff;}
    .radio-card input{margin-top:4px; transform: scale(1.2);}
    .radio-card div{font-size:14px;line-height:1.55;}

    .stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:16px}@media (max-width:900px){.stats{grid-template-columns:repeat(2,minmax(0,1fr))}}
    .stat{background:rgba(255,255,255,.9);border:1px solid rgba(219,227,238,.95);border-radius:20px;padding:16px;box-shadow:var(--shadow)}.stat .num{font-size:24px;font-weight:800;margin:0 0 4px}.stat .lbl{color:var(--muted);font-size:13px}
    .category-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}@media (max-width:900px){.category-grid{grid-template-columns:1fr}}
    .category{border:1px solid var(--border);border-radius:20px;background:#fff;padding:16px;box-shadow:var(--shadow)}.category h4{margin:0 0 6px}.category p{margin:0;color:var(--muted);line-height:1.55}.category .count{margin-top:10px;display:inline-block;background:#eff6ff;color:#1d4ed8;border:1px solid #dbeafe;padding:6px 10px;border-radius:999px;font-size:12px}
    .content-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:16px}@media (max-width:900px){.content-grid{grid-template-columns:1fr}}
    .post-list{display:grid;gap:12px}.post{border:1px solid var(--border);border-radius:18px;background:#fff;padding:16px;box-shadow:var(--shadow)}.post h4{margin:0 0 8px}.post p{margin:0;color:var(--muted);line-height:1.6}
    .accordion details{border:1px solid var(--border);border-radius:16px;background:#fff;overflow:hidden;box-shadow:var(--shadow)} .accordion details+details{margin-top:12px}
    .accordion summary{cursor:pointer;padding:14px 16px;list-style:none;display:flex;align-items:center;justify-content:space-between;gap:12px;font-weight:800} .accordion summary::-webkit-details-marker{display:none} .accordion summary::after{content:'+';font-size:20px;color:var(--muted)} .accordion details[open] summary::after{content:'–'} .accordion .body{padding:0 16px 16px;color:var(--muted);line-height:1.65}
    .progress-wrap{width:100%;height:12px;border-radius:999px;background:#e2e8f0;overflow:hidden;margin:10px 0 16px}.progress-bar{height:100%;width:0%;background:linear-gradient(90deg,#1d4ed8,#0ea5e9);transition:width .2s ease}
    .question-list{display:grid;gap:12px}.question-item{border:1px solid var(--border);border-radius:16px;padding:14px;background:#fff}.question-item header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:10px}.question-item h4{margin:0;font-size:16px;line-height:1.45}.question-item .meta{color:var(--muted);font-size:13px;margin-top:4px}
    .q-image,.answer-thumb{width:100%;max-height:240px;object-fit:contain;border-radius:14px;border:1px solid var(--border);background:#f8fafc;margin:10px 0}
    .option-list{display:grid;gap:8px;margin-top:10px}.option{border:1px solid var(--border);border-radius:12px;padding:10px 12px;background:var(--surface-2);display:flex;justify-content:space-between;gap:10px;align-items:flex-start}.option.selected{outline:2px solid rgba(29,78,216,.35);background:#eff6ff}.option label{cursor:pointer;width:100%;display:flex;justify-content:space-between;gap:10px;align-items:flex-start}.score{color:var(--muted);font-size:13px;flex:0 0 auto}
    .split{display:grid;grid-template-columns:1.2fr .8fr;gap:16px}@media (max-width:900px){.split{grid-template-columns:1fr}}
    .table-wrap{overflow:auto;border:1px solid var(--border);border-radius:16px} table{border-collapse:collapse;width:100%;background:#fff;min-width:760px} th,td{padding:12px 10px;border-bottom:1px solid #eef2f7;text-align:left;vertical-align:top} th{background:#f8fafc;position:sticky;top:0;z-index:1} tr:last-child td{border-bottom:none}
    .login-overlay,.modal-backdrop{position:fixed;inset:0;background:rgba(15,23,42,.58);display:none;align-items:center;justify-content:center;padding:16px;z-index:45}.login-overlay.show,.modal-backdrop.show{display:flex}
    .login-card,.modal{width:min(920px,100%);max-height:92vh;overflow:auto;background:#fff;border-radius:22px;box-shadow:0 24px 80px rgba(0,0,0,.22);padding:20px}
    .login-card{width:min(460px,100%)} .modal header,.login-card header{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px} .modal header h3,.login-card header h3{margin:0}
    .editor-grid{display:grid;gap:12px}.editor-grid.cols-2{grid-template-columns:repeat(2,minmax(0,1fr))}@media (max-width:900px){.editor-grid.cols-2{grid-template-columns:1fr}}
    .choice-grid{display:grid;gap:10px}.choice-row{display:grid;grid-template-columns:1.2fr .5fr .9fr auto;gap:8px;align-items:start}@media (max-width:760px){.choice-row{grid-template-columns:1fr}}
    .help-box{background:#f8fafc;border:1px dashed #cbd5e1;border-radius:16px;padding:14px;color:#334155;line-height:1.65}.small{font-size:13px;color:var(--muted)}.footer-note{color:var(--muted);font-size:13px;line-height:1.6}
    .toast{position:fixed;left:50%;bottom:18px;transform:translateX(-50%);background:#0f172a;color:#fff;padding:12px 16px;border-radius:999px;box-shadow:var(--shadow);z-index:50;opacity:0;pointer-events:none;transition:.2s ease;max-width:min(92vw,720px);text-align:center}.toast.show{opacity:1;bottom:22px}
    .page{display:none}.page.active{display:block; animation: fadeIn 0.3s ease;}
    @keyframes fadeIn{from{opacity:0; transform:translateY(10px)} to{opacity:1; transform:translateY(0)}}
    .home-shell{display:grid;gap:16px}.home-shell .hero{margin-bottom:0}
    .navline{display:flex;gap:8px;flex-wrap:wrap}.navchip{padding:8px 12px;border-radius:999px;background:#fff;border:1px solid var(--border);font-size:13px}
    .editor-columns{display:grid;grid-template-columns:1fr 1fr;gap:16px}@media (max-width:900px){.editor-columns{grid-template-columns:1fr}}
    .raw-json{min-height:320px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px}
  </style>
</head>
<body>
  <div class="bg-layer" id="bgLayer"></div>
  <div class="bg-overlay"></div>
  <div class="app">
    <header class="topbar">
      <div class="topbar-inner">
        <div class="brand">
          <div class="logo" id="logoBox"><span id="logoFallback">SP</span><img id="logoImg" class="hidden" alt="Logo sekolah"></div>
          <div>
            <h1 id="brandTitle">Alat Tes Psikologi Internal</h1>
            <p id="brandSubtitle">SMK PGRI 2 Kediri · responsif untuk desktop, tablet, dan Android</p>
          </div>
        </div>
        <div class="pill-row">
          <button class="pill ghost" id="btnHome">Beranda</button>
          <button class="pill ghost" id="btnAdminLogin">Admin</button>
          <button class="pill primary" id="btnStudentQuick">Mulai Tes</button>
        </div>
      </div>
    </header>

    <main class="container">
      
      <!-- HALAMAN BERANDA -->
      <section id="pageHome" class="page active">
        <div class="home-shell">
          <div class="hero">
            <div class="hero-banner">
              <h2 id="homeHeroTitle">Tes psikologi internal yang cepat, rapi, dan nyaman dibuka di semua perangkat.</h2>
              <p id="homeHeroText">Masuk sebagai siswa, kerjakan tes, dan simpan progres secara otomatis. Beranda dibuat bergaya clean seperti template modern dengan hero besar, kartu ringkas, statistik, konten terstruktur, dan FAQ.</p>
              <div class="hero-meta" id="homeHeroPills">
                <span class="meta-badge">Teks & gambar</span>
                <span class="meta-badge">Jawaban bergambar</span>
                <span class="meta-badge">Cloud spreadsheet</span>
                <span class="meta-badge">Layout responsif</span>
              </div>
            </div>
            <div class="search-card">
              <h3>Mulai Mengikuti Tes</h3>
              <p>Silakan isi identitas diri yang diperlukan dan mulai kerjakan soal-soal tes secara berurutan. Progres akan tersimpan otomatis.</p>
              <div class="row" style="justify-content:center; gap: 16px;">
                <button class="btn blue" style="font-size:16px; padding:16px 32px;" onclick="showPage('identity')">Isi Data Diri & Mulai Tes</button>
                <button class="btn outline" style="font-size:16px; padding:16px 32px;" onclick="promptResumeDraft()">Lanjutkan Tes (Draft)</button>
              </div>
              <p class="small" style="margin-top:20px">Menu admin ada di pojok kanan atas.</p>
            </div>
          </div>

          <div class="stats" id="homeStats"></div>

          <div class="grid cols-2">
            <div class="card accordion" style="padding:0">
              <details open>
                <summary>Petunjuk penggunaan</summary>
                <div class="body" id="homeGuide">1. Siswa wajib mengisi kelengkapan data sebelum tes.<br>2. Soal dapat berisi gambar dan jawaban bergambar.<br>3. Super admin dapat mengubah konten, warna, logo, dan elemen website.<br>4. Admin biasa hanya melihat rekap hasil.</div>
              </details>
              <details>
                <summary>Status aplikasi</summary>
                <div class="body" id="homeStatus">Memuat status...</div>
              </details>
            </div>
            <div class="card">
              <div class="section-title"><h3>Fitur utama</h3></div>
              <div class="navline" id="homeFeatureChips"></div>
              <div class="help-box" style="margin-top:12px" id="homeSummaryBox">Beranda ini dapat diubah dari panel super admin.</div>
            </div>
          </div>

          <div class="content-grid">
            <div>
              <div class="section-title"><h3 id="homeCategoryTitle">Kategori tes</h3></div>
              <div class="category-grid" id="homeCategories"></div>
            </div>
            <div>
              <div class="section-title"><h3 id="homeNewsTitle">Info / pengumuman</h3></div>
              <div class="post-list" id="homePosts"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- HALAMAN PENGISIAN DATA DIRI (BARU) -->
      <section id="pageIdentity" class="page">
        <div class="card" style="max-width: 900px; margin: 0 auto;">
          <div class="section-title" style="margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 16px;">
            <div>
              <h3 style="font-size: 24px;">Formulir Data Diri Siswa</h3>
              <small style="color:var(--danger); font-weight:600;">Semua kolom di bawah ini WAJIB DIISI sebelum dapat melanjutkan tes.</small>
            </div>
            <button class="btn gray small" onclick="showPage('home')">Kembali</button>
          </div>

          <div class="form-group-title">1. Identitas Diri</div>
          <div class="form-grid">
            <div class="field"><label>Email (Untuk menyimpan progres) *</label><input id="idEmail" class="input" type="email" placeholder="nama@email.com"></div>
            <div class="field"><label>Nama Lengkap *</label><input id="idNama" class="input" type="text" placeholder="Nama Lengkap"></div>
            <div class="field"><label>Jenis Kelamin *</label><select id="idJK" class="input"><option value="">-- Pilih --</option><option value="Laki-laki">Laki-laki</option><option value="Perempuan">Perempuan</option></select></div>
            <div class="field"><label>Tempat & Tanggal Lahir *</label><div class="row" style="gap:8px;"><input id="idTempatLahir" class="input" placeholder="Tempat Lahir" style="flex:1;"><input id="idTglLahir" class="input" type="date" style="flex:1.2;"></div></div>
            <div class="field"><label>Usia (Angka) *</label><input id="idUsia" class="input" type="number" placeholder="Contoh: 16"></div>
            <div class="field"><label>Kelas *</label><select id="idKelas" class="input"><option value="">-- Pilih Kelas --</option><option value="X">X</option><option value="XI">XI</option><option value="XII">XII</option></select></div>
            <div class="field"><label>Jurusan *</label><input id="idJurusan" class="input" type="text" placeholder="Contoh: TKJ, AKL, dll"></div>
            <div class="field"><label>Nama Sekolah *</label><input id="idSekolah" class="input" type="text" value="SMK PGRI 2 Kediri"></div>
          </div>

          <div class="form-group-title">2. Data Keluarga</div>
          <div class="form-grid">
            <div class="field"><label>Nama Orang Tua / Wali *</label><input id="idNamaOrtu" class="input" type="text" placeholder="Nama Ayah/Ibu/Wali"></div>
            <div class="field"><label>Pekerjaan Ayah *</label><input id="idKerjaAyah" class="input" type="text"></div>
            <div class="field"><label>Pekerjaan Ibu *</label><input id="idKerjaIbu" class="input" type="text"></div>
            <div class="field"><label>Pendidikan Terakhir Ayah *</label><input id="idPendAyah" class="input" type="text"></div>
            <div class="field"><label>Pendidikan Terakhir Ibu *</label><input id="idPendIbu" class="input" type="text"></div>
            <div class="field"><label>Jumlah Saudara Kandung *</label><input id="idJmlSaudara" class="input" type="number" placeholder="Angka"></div>
            <div class="field"><label>Anak Ke- *</label><input id="idAnakKe" class="input" type="number" placeholder="Angka"></div>
            <div class="field"><label>Status Orang Tua *</label><select id="idStatusOrtu" class="input"><option value="">-- Pilih --</option><option value="Kandung">Kandung</option><option value="Tiri">Tiri</option><option value="Angkat">Angkat</option></select></div>
            <div class="field"><label>Status Perkawinan Ortu *</label><select id="idKawinOrtu" class="input"><option value="">-- Pilih --</option><option value="Menikah">Menikah</option><option value="Bercerai">Bercerai</option><option value="Meninggal">Meninggal</option></select></div>
            <div class="field"><label>Tinggal Dengan *</label><select id="idTinggal" class="input"><option value="">-- Pilih --</option><option value="Orang Tua">Orang Tua</option><option value="Wali">Wali</option><option value="Lainnya">Lainnya</option></select></div>
          </div>

          <div class="form-group-title">3. Pola Asuh</div>
          <p style="font-size:14px; margin-bottom:12px; font-weight: 600;">Cara orang tua / wali mengasuh saya adalah… (Pilih Salah Satu) *</p>
          <div class="field">
            <label class="radio-card"><input type="radio" name="polaAsuh" value="Demokratis"><div><b>Demokratis:</b> Orang tua memberi aturan jelas, mau mendengarkan saya, dan tetap memberi kebebasan yang bertanggung jawab.</div></label>
            <label class="radio-card"><input type="radio" name="polaAsuh" value="Otoriter"><div><b>Otoriter:</b> Orang tua banyak aturan, harus saya turuti, dan jarang memberi kesempatan saya berpendapat.</div></label>
            <label class="radio-card"><input type="radio" name="polaAsuh" value="Permisif"><div><b>Permisif:</b> Orang tua sangat membebaskan saya dan jarang memberi batasan atau aturan.</div></label>
            <label class="radio-card"><input type="radio" name="polaAsuh" value="Neglectful"><div><b>Neglectful:</b> Orang tua kurang perhatian, jarang terlibat, dan membiarkan saya berjalan sendiri.</div></label>
          </div>

          <div style="margin-top:32px; display:flex; justify-content:center;">
            <button class="btn blue" style="font-size:18px; padding:16px 40px; width:100%; max-width:400px;" onclick="validateAndStartTest()">Simpan & Lanjut ke Tes</button>
          </div>
        </div>
      </section>

      <!-- HALAMAN TES -->
      <section id="pageTest" class="page">
        <div class="card">
          <div class="section-title">
            <div>
              <h3>Tes Siswa</h3>
              <small id="testUserLabel">Peserta: -</small>
            </div>
            <div class="row" style="justify-content:flex-end;flex:0 0 auto">
              <button class="btn outline small" id="btnSaveDraft">Simpan Progres</button>
              <button class="btn gray small" id="btnBackHomeFromTest">Berhenti (Home)</button>
            </div>
          </div>
          <div class="progress-wrap"><div class="progress-bar" id="progressBar"></div></div>
          <div id="questionHost"></div>
