    function renderQuestions(){el('questionCountBadge').textContent=`${state.questions.length} soal aktif`;const host=el('questionList');if(!state.questions.length){host.innerHTML='<div class="help-box">Belum ada soal. Tambahkan soal pertama.</div>';return}host.innerHTML=state.questions.map((q,idx)=>`<div class="question-item"><header><div><h4>${idx+1}. ${esc(q.prompt||'(Tanpa teks soal)')}</h4><div class="meta">Tipe: ${q.type==='mcq'?'Pilihan ganda':'Isian'}</div></div>${state.admin?.role==='superadmin'?`<div class="row" style="flex:0 0 auto;justify-content:flex-end"><button class="btn outline small" onclick="editQuestion('${q.id}')">Edit</button><button class="btn danger small" onclick="deleteQuestion('${q.id}')">Hapus</button></div>`:''}</header>${q.image?`<img class="q-image" src="${q.image}">`:''}${q.type==='mcq'?`<div class="option-list">${q.options.map(opt=>`<div class="option"><div style="width:100%"><div>${esc(opt.text)}</div>${opt.image?`<img class="answer-thumb" src="${opt.image}">`:''}</div><span class="score">Skor ${Number(opt.score||0)}</span></div>`).join('')}</div>`:'<div class="small">Isian teks</div>'}</div>`).join('')}
    
    function renderResults(){
