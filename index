    function uid(){return 'q_'+Math.random().toString(36).slice(2,9)+Date.now().toString(36)}
    function nowText(){return new Date().toLocaleString('id-ID',{dateStyle:'medium',timeStyle:'short'})}
    function safeParse(v,f){try{return v?JSON.parse(v):f}catch{return f}}
    function seedQuestions(){return[{id:uid(),type:'mcq',prompt:'Saya merasa mudah bergaul dengan teman baru.',image:'',options:[{text:'Sangat tidak setuju',score:0,image:''},{text:'Tidak setuju',score:1,image:''},{text:'Setuju',score:2,image:''},{text:'Sangat setuju',score:3,image:''}]}]} 
    
    function loadData(){state.questions=safeParse(localStorage.getItem(STORAGE_KEYS.questions),[]);state.results=safeParse(localStorage.getItem(STORAGE_KEYS.results),[]);state.admin=safeParse(localStorage.getItem(STORAGE_KEYS.adminSession),null);if(!Array.isArray(state.questions)||!state.questions.length){state.questions=seedQuestions();localStorage.setItem(STORAGE_KEYS.questions,JSON.stringify(state.questions))}}
    function toast(msg){const t=el('toast');t.textContent=msg;t.classList.add('show');clearTimeout(window._tt);window._tt=setTimeout(()=>t.classList.remove('show'),2800)}
    
    function showPage(page){
        state.page=page;
        ['pageHome','pageIdentity','pageTest','pageAdmin','pageSuper'].forEach(id=>{
            const elm = el(id);
            if(elm) elm.classList.remove('active');
        });
        const map={home:'pageHome',identity:'pageIdentity',test:'pageTest',admin:'pageAdmin',super:'pageSuper'};
