    /* VALIDASI & TES FLOW */
    function draftKey(email){return `${STORAGE_KEYS.drafts}_${email.toLowerCase()}`}
    
    function validateAndStartTest() {
        const ids = ['idEmail','idNama','idJK','idTempatLahir','idTglLahir','idUsia','idKelas','idJurusan','idSekolah','idNamaOrtu','idKerjaAyah','idKerjaIbu','idPendAyah','idPendIbu','idJmlSaudara','idAnakKe','idStatusOrtu','idKawinOrtu','idTinggal'];
        let valid = true;
        let data = {};
        for(let id of ids) {
            const val = el(id).value.trim();
            if(!val) valid = false;
            data[id] = val;
        }

        const pa = document.querySelector('input[name="polaAsuh"]:checked');
        if(!pa) valid = false;
        else data.polaAsuh = pa.value;

        if(!valid) {
            toast('Peringatan: Harap isi SELURUH kolom (Identitas, Keluarga, & Pola Asuh) terlebih dahulu!');
            return;
        }
        
        if(!data.idEmail.includes('@')){
            toast('Pastikan format email sudah benar.');
            el('idEmail').focus();
            return;
        }

        state.studentIdentity = data;
        state.draftEmail = data.idEmail;

        const draft = safeParse(localStorage.getItem(draftKey(data.idEmail)), null);
        state.answers = draft?.answers || {};
        state.testIndex = draft?.index || 0;

        showPage('test');
        toast('Data disimpan. Selamat mengerjakan!');
    }

    function saveDraftOnly(){
        const email=state.draftEmail;
        if(!email)return;
        localStorage.setItem(draftKey(email),JSON.stringify({
            email, identity: state.studentIdentity, index: state.testIndex, answers: state.answers, updatedAt: new Date().toISOString()
        }))
    }

    function promptResumeDraft() {
        const em = prompt("Masukkan email Anda untuk memuat progres yang tersimpan:");
        if(!em) return;
        const draft = safeParse(localStorage.getItem(draftKey(em)), null);
        if(!draft) {
            toast("Data tes belum ditemukan untuk email ini. Silakan 'Isi Data Diri'.");
            return;
        }
        state.draftEmail = draft.email;
        state.studentIdentity = draft.identity || {};
        state.answers = draft.answers || {};
        state.testIndex = draft.index || 0;
        showPage('test');
        toast('Berhasil memuat draft progres tes.');
    }

    function renderTest(){
        const ident = state.studentIdentity || {};
        el('testUserLabel').textContent = ident.idNama ? `${ident.idNama} (${ident.idKelas} ${ident.idJurusan})` : 'Peserta Aktif';
        const q=state.questions[state.testIndex];
        if(!q){el('questionHost').innerHTML='<div class="help-box">Belum ada soal tersedia.</div>';el('progressBar').style.width='0%';return}
        el('progressBar').style.width=((state.testIndex+1)/state.questions.length*100)+'%';
        
        let content=`<div class="question-item" style="border:none;padding:0"><div class="section-title" style="margin-bottom:8px"><h3>Soal ${state.testIndex+1} dari ${state.questions.length}</h3><small>${q.type==='mcq'?'Pilihan ganda':'Isian'}</small></div><h4 style="font-size:18px;margin:0 0 12px;line-height:1.5">${esc(q.prompt||'')}</h4>${q.image?`<img class="q-image" src="${q.image}">`:''}`;
        if(q.type==='mcq'){
            const current=state.answers[q.id]||'';
            content+=`<div class="option-list">${q.options.map((opt,idx)=>{const sel=current===String(idx);return `<div class="option ${sel?'selected':''}"><label><span style="display:block;width:100%"><span style="display:flex;gap:10px;align-items:flex-start;width:100%"><input type="radio" name="answer_${q.id}" value="${idx}" ${sel?'checked':''} onchange="saveAnswer('${q.id}',this.value)"><span style="display:block"><span>${esc(opt.text)}</span>${opt.image?`<img class="answer-thumb" src="${opt.image}">`:''}</span></span></span></label><span class="score hidden">Skor ${Number(opt.score||0)}</span></div>`}).join('')}</div>`
        }else{
            const current=state.answers[q.id]||'';
            content+=`<div class="field" style="margin-top:12px"><textarea id="textAnswer" placeholder="Tulis jawaban...">${esc(current)}</textarea></div>`
        }
        content+='</div>';
        el('questionHost').innerHTML=content;
        el('btnPrevQ').disabled=state.testIndex<=0;
        el('btnNextQ').disabled=state.testIndex>=state.questions.length-1;
    }
    
    function saveAnswer(qid,val){state.answers[qid]=val;saveDraftOnly()}
    function goQuestion(delta){const q=state.questions[state.testIndex];if(q&&q.type==='text'){const ta=el('textAnswer');if(ta)state.answers[q.id]=ta.value}saveDraftOnly();state.testIndex=Math.max(0,Math.min(state.questions.length-1,state.testIndex+delta));renderTest()}
    
    function collectTestData(){
        let total=0; const parts=[];
        for(const q of state.questions){
            const ans=state.answers[q.id];
            if(q.type==='mcq'){
                const opt=q.options?.[Number(ans)];
                if(opt){total+=Number(opt.score||0);parts.push(`${q.prompt.slice(0,20)}: ${opt.text}`)}else parts.push(`${q.prompt.slice(0,20)}: -`)
            }else parts.push(`${q.prompt.slice(0,20)}: ${String(ans||'-').slice(0,30)}`)
        }
        return {
            email: state.studentIdentity.idEmail || '',
            score: total,
            summary: parts.join(' | '),
            identityFull: state.studentIdentity
        }
    }
    
    async function submitTest(){
        if(!state.questions.length){toast('Tidak ada soal untuk dikirim.');return}
        const data=collectTestData();
        const record={time:nowText(), email:data.email, score:data.score, summary:data.summary, identityFull:data.identityFull, answers:state.answers, submittedAt:new Date().toISOString()};
        state.results.push(record);
        saveAll();
        localStorage.removeItem(draftKey(state.draftEmail));
        toast('Hasil tes berhasil disimpan!');
        
        const endpoint=(state.config.sheetEndpoint||'').trim();
        if(endpoint){
            try{
                await fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({source:'SMK PGRI 2 Kediri',type:'result',record})})
            }catch(e){console.warn('Sync Spreadsheet Failed', e)}
        }
        state.answers={}; state.testIndex=0; state.studentIdentity={}; state.draftEmail='';
        showPage('home');
    }

    /* EDITOR SOAL (Super Admin) */
    function renderQuestionEditor(q){el('questionModalTitle').textContent=q?'Edit Soal':'Tambah Soal';el('qPrompt').value=q?.prompt||'';el('qType').value=q?.type||'mcq';el('qImageUrl').value=q?.image&&q.image.startsWith('http')?q.image:'';state.pendingImageData=q?.image&&q.image.startsWith('data:')?q.image:'';el('mcqEditor').classList.toggle('hidden',q?.type==='text');el('textEditor').classList.toggle('hidden',q?.type!=='text');renderOptionEditor(q?.options?.length?q.options:[{text:'',score:0,image:''},{text:'',score:1,image:''},{text:'',score:2,image:''},{text:'',score:3,image:''}])}
    function openQuestionModal(editId=null){if(!requireSuper())return;state.editingQuestionId=editId;const q=editId?state.questions.find(x=>x.id===editId):null;renderQuestionEditor(q);el('questionModalBackdrop').classList.add('show')}
    function closeQuestionModal(){el('questionModalBackdrop').classList.remove('show')}
    function editQuestion(id){openQuestionModal(id)} function deleteQuestion(id){if(!requireSuper())return;if(!confirm('Hapus soal ini?'))return;state.questions=state.questions.filter(q=>q.id!==id);saveAll();renderQuestions();renderHome();toast('Soal dihapus.')}
    function removeOptionRow(btn){btn.closest('.choice-row')?.remove()}
    async function handleOptionImageFile(input){const file=input.files&&input.files[0];const row=input.closest('.choice-row');if(!file||!row)return;const data=await fileToDataUrl(file);row.querySelector('.opt-image-data').value=data;row.querySelector('.opt-image-url').value='';let img=row.querySelector('.answer-thumb-inline');if(!img){img=document.createElement('img');img.className='answer-thumb answer-thumb-inline';row.querySelector('.field:nth-child(3)').appendChild(img)}img.src=data;}
    function addOptionRow(){const host=el('optionEditor');const idx=host.querySelectorAll('.choice-row').length+1;const div=document.createElement('div');div.className='choice-row';div.innerHTML=`<div class="field" style="margin:0"><label>Teks opsi ${idx}</label><input class="input opt-text" placeholder="Teks opsi ${idx}"></div><div class="field" style="margin:0"><label>Skor</label><input class="input opt-score" type="number" min="0" step="1" value="0"></div><div class="field" style="margin:0"><label>Gambar jawaban</label><input class="input opt-image-url" type="url" placeholder="URL gambar"><input class="input opt-image-file" type="file" accept="image/*" onchange="handleOptionImageFile(this)"><input type="hidden" class="opt-image-data" value=""></div><div class="field" style="margin:0"><label>Aksi</label><button class="btn danger small" type="button" onclick="removeOptionRow(this)">Hapus</button></div>`;host.appendChild(div)}
    function renderOptionEditor(options){const host=el('optionEditor');host.innerHTML=(options&&options.length?options:[{text:'',score:0,image:''}]).map((opt,idx)=>`<div class="choice-row"><div class="field" style="margin:0"><label>Teks opsi ${idx+1}</label><input class="input opt-text" value="${esc(opt.text||'')}" placeholder="Teks opsi ${idx+1}"></div><div class="field" style="margin:0"><label>Skor</label><input class="input opt-score" type="number" min="0" step="1" value="${Number(opt.score||0)}"></div><div class="field" style="margin:0"><label>Gambar jawaban</label><input class="input opt-image-url" type="url" placeholder="URL" value="${esc(opt.image&&opt.image.startsWith('http')?opt.image:'')}"><input class="input opt-image-file" type="file" accept="image/*" onchange="handleOptionImageFile(this)"><input type="hidden" class="opt-image-data" value="${esc(opt.image&&opt.image.startsWith('data:')?opt.image:'')}">${opt.image?`<img class="answer-thumb answer-thumb-inline" src="${opt.image}">`:''}</div><div class="field" style="margin:0"><label>Aksi</label><button class="btn danger small" type="button" onclick="removeOptionRow(this)">Hapus</button></div></div>`).join('')}
    function gatherOptions(){return[...document.querySelectorAll('#optionEditor .choice-row')].map(row=>({text:row.querySelector('.opt-text').value.trim(),score:Number(row.querySelector('.opt-score').value||0),image:row.querySelector('.opt-image-data').value.trim()||row.querySelector('.opt-image-url').value.trim()})).filter(x=>x.text||x.image)}
    async function saveQuestion(){if(!requireSuper())return;const prompt=el('qPrompt').value.trim();const type=el('qType').value;if(!prompt){toast('Teks soal belum diisi.');return}let image=state.pendingImageData||el('qImageUrl').value.trim();if(el('qImageFile').files&&el('qImageFile').files[0])image=await fileToDataUrl(el('qImageFile').files[0]);const question={id:state.editingQuestionId||uid(),type,prompt,image,options:type==='mcq'?gatherOptions():[]};if(type==='mcq'&&question.options.length<2){toast('Pilihan ganda minimal 2 opsi.');return}if(state.editingQuestionId)state.questions=state.questions.map(q=>q.id===state.editingQuestionId?question:q);else state.questions.push(question);saveAll();renderQuestions();renderHome();closeQuestionModal();toast('Soal berhasil disimpan.')}
    function fileToDataUrl(file){return new Promise((resolve,reject)=>{const r=new FileReader();r.onload=()=>resolve(String(r.result));r.onerror=reject;r.readAsDataURL(file)})}
    
    /* UTILS & EXPORT */
    function exportCSV(){
        if(!state.results.length){toast('Belum ada data untuk diekspor.');return}
        // CSV Headers yang diperluas sesuai Form Identity
        const headers=['time','email','nama_lengkap','jenis_kelamin','tempat_lahir','tgl_lahir','usia','kelas','jurusan','nama_ortu','kerja_ayah','kerja_ibu','pend_ayah','pend_ibu','jml_saudara','anak_ke','status_ortu','kawin_ortu','tinggal_dengan','pola_asuh','score','summary'];
        const rows=state.results.map(r=>{
            const ident = r.identityFull || {};
            const rowData = [
                r.time, r.email, ident.idNama, ident.idJK, ident.idTempatLahir, ident.idTglLahir, ident.idUsia, ident.idKelas, ident.idJurusan,
                ident.idNamaOrtu, ident.idKerjaAyah, ident.idKerjaIbu, ident.idPendAyah, ident.idPendIbu, ident.idJmlSaudara, ident.idAnakKe,
                ident.idStatusOrtu, ident.idKawinOrtu, ident.idTinggal, ident.polaAsuh, r.score, r.summary
            ];
            return rowData.map(val=>`"${String(val??'').replaceAll('"','""')}"`).join(',');
        });
        downloadFile('rekap_tes_lengkap_psikologi.csv',[headers.join(','),...rows].join('\n'),'text/csv;charset=utf-8;');
    }
    function downloadFile(filename,content,mime){const blob=new Blob([content],{type:mime});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=filename;document.body.appendChild(a);a.click();a.remove();setTimeout(()=>URL.revokeObjectURL(url),1000)}
    async function syncResults(){if(!state.config.sheetEndpoint)return toast('Isi endpoint dulu.');try{await fetch(state.config.sheetEndpoint,{method:'POST',body:JSON.stringify({source:'SMK PGRI 2 Kediri',type:'bulk-results',results:state.results})});toast('Dikirim ke spreadsheet.')}catch(e){toast('Gagal sinkronisasi.')}}
    async function testEndpoint(){try{const res=await fetch(el('sheetEndpoint').value,{method:'POST',body:JSON.stringify({type:'ping'})});toast(`Tes endpoint terkirim: ${res.status}`)}catch(e){toast('Gagal tes endpoint.')}}
    
    function saveAdminSettings(){state.config.sheetEndpoint=el('sheetEndpoint').value.trim()||DEFAULT_ENDPOINT;saveAll();toast('Disimpan.')}
    function saveBranding(){if(!requireSuper())return;const b=state.config.branding;b.title=el('brandingTitle').value;b.subtitle=el('brandingSubtitle').value;b.primaryColor=el('primaryColor').value;b.textColor=el('textColor').value;b.bgColor=el('bgColor').value;b.heroColor=el('heroColor').value;saveAll();applyBranding();toast('Branding disimpan.')}
    function saveHomepage(){if(!requireSuper())return;const h=state.config.home;h.heroTitle=el('homeHeroTitleInput').value;h.heroText=el('homeHeroTextInput').value;h.summaryBox=el('homeSummaryBoxInput').value;h.footerBox=el('homeFooterBoxInput').value;h.features=el('homeFeaturesInput').value.split('\n').filter(Boolean);h.guide=el('homeGuideInput').value;saveAll();renderHome();toast('Beranda disimpan.')}
    function saveSiteJson(){if(!requireSuper())return;try{state.config=JSON.parse(el('siteJsonEditor').value);saveAll();applyBranding();renderHome();renderSuperForm();toast('JSON disimpan.');}catch(e){toast('JSON tidak valid.')}}
    function resetBranding(){if(!requireSuper())return;state.config.branding=structuredClone(DEFAULT_CONFIG.branding);saveAll();applyBranding();renderSuperForm();toast('Branding direset.')}
    function handleBrandingFile(input,key){const f=input.files?.[0];if(!f)return;fileToDataUrl(f).then(d=>{state.config.branding[key]=d;saveAll();applyBranding();toast('Gambar diperbarui.')})}
    function logout(){state.admin=null;localStorage.removeItem(STORAGE_KEYS.adminSession);toast('Admin keluar.');showPage('home')}

    function bindEvents(){
        el('btnAdminLogin').addEventListener('click',openLogin);
        el('btnCloseLogin').addEventListener('click',closeLogin);
        el('btnDoLogin').addEventListener('click',doLogin);
        el('btnHome').addEventListener('click',()=>showPage('home'));
        el('btnStudentQuick').addEventListener('click',()=>showPage('identity'));
        
        el('btnBackHomeFromTest').addEventListener('click',()=>showPage('home'));
        el('btnBackHomeFromAdmin').addEventListener('click',()=>showPage('home'));
        el('btnBackHomeFromSuper').addEventListener('click',()=>showPage('home'));
        
        el('btnSaveDraft').addEventListener('click',()=>{saveDraftOnly();toast('Progres tersimpan.')});
        el('btnPrevQ').addEventListener('click',()=>goQuestion(-1));
        el('btnNextQ').addEventListener('click',()=>goQuestion(1));
        el('btnFinishTest').addEventListener('click',()=>{const q=state.questions[state.testIndex];if(q&&q.type==='text'){const ta=el('textAnswer');if(ta)state.answers[q.id]=ta.value}submitTest()});
        
        document.querySelectorAll('#pageAdmin .tab').forEach(btn=>btn.addEventListener('click',()=>{state.adminTab=btn.dataset.tab;renderTabs()}));
        document.querySelectorAll('#pageSuper .tab').forEach(btn=>btn.addEventListener('click',()=>{state.superTab=btn.dataset.superTab;renderSuperTabs()}));
        
        el('btnExportCSV').addEventListener('click',exportCSV);el('btnSyncNow').addEventListener('click',syncResults);
        el('btnSaveAdminSettings').addEventListener('click',saveAdminSettings);el('btnTestEndpoint').addEventListener('click',testEndpoint);
        el('btnLogoutAdmin').addEventListener('click',logout);el('btnLogoutSuper').addEventListener('click',logout);
        
        el('btnAddQuestion').addEventListener('click',()=>openQuestionModal());el('btnCloseQuestionModal').addEventListener('click',closeQuestionModal);
        el('btnSaveQuestion').addEventListener('click',saveQuestion);el('btnAddOption').addEventListener('click',addOptionRow);
        el('qType').addEventListener('change',e=>{const v=e.target.value;el('mcqEditor').classList.toggle('hidden',v!=='mcq');el('textEditor').classList.toggle('hidden',v!=='text')});
        
        el('brandingLogoFile').addEventListener('change',e=>handleBrandingFile(e.target,'logoData'));
        el('brandingBackgroundFile').addEventListener('change',e=>handleBrandingFile(e.target,'backgroundData'));
        el('btnSaveBranding').addEventListener('click',saveBranding);el('btnResetBranding').addEventListener('click',resetBranding);
        el('btnSaveHomepage').addEventListener('click',saveHomepage);el('btnSaveSiteJson').addEventListener('click',saveSiteJson);
        el('btnReloadSiteJson').addEventListener('click',()=>{el('siteJsonEditor').value=JSON.stringify(state.config,null,2);toast('Dimuat ulang.')});
    }

    // Expose global methods
    window.showPage = showPage;
    window.promptResumeDraft = promptResumeDraft;
    window.validateAndStartTest = validateAndStartTest;
    window.editQuestion=editQuestion; window.deleteQuestion=deleteQuestion;
    window.saveAnswer=saveAnswer; window.handleOptionImageFile=handleOptionImageFile; window.removeOptionRow=removeOptionRow;

    function init(){
        loadData();
        state.config.sheetEndpoint=state.config.sheetEndpoint||DEFAULT_ENDPOINT;
        bindEvents();applyBranding();renderHome();renderResults();renderSuperForm();
        if(state.admin){showPage(state.admin.role==='superadmin'?'super':'admin')}else{showPage('home')}
    }
    init();
  </script>
</body>
</html>
