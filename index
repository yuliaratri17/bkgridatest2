        if(page==='test')renderTest();
        if(page==='admin')renderAdmin();
        if(page==='super')renderSuper();
        window.scrollTo({top:0,behavior:'smooth'})
    }

    function applyBranding(){const b=state.config.branding;document.documentElement.style.setProperty('--primary',b.primaryColor);document.documentElement.style.setProperty('--primary-2',b.heroColor);document.documentElement.style.setProperty('--text',b.textColor);document.documentElement.style.setProperty('--bg',b.bgColor);el('brandTitle').textContent=b.title;el('brandSubtitle').textContent=b.subtitle;el('homeHeroTitle').textContent=state.config.home.heroTitle;el('homeHeroText').textContent=state.config.home.heroText;el('homeSummaryBox').textContent=state.config.home.summaryBox;el('homeFooterBox').textContent=state.config.home.footerBox;el('homeCategoryTitle').textContent=state.config.home.categoryTitle;el('homeNewsTitle').textContent=state.config.home.newsTitle;const bg=el('bgLayer');bg.style.backgroundImage=b.backgroundData?`linear-gradient(180deg, rgba(255,255,255,.72), rgba(255,255,255,.68)), url('${b.backgroundData}')`:'linear-gradient(180deg,#eef4ff 0%, #f7fafc 40%, #f4f7fb 100%)';if(b.logoData){el('logoImg').src=b.logoData;el('logoImg').classList.remove('hidden');el('logoFallback').classList.add('hidden')}else{el('logoImg').classList.add('hidden');el('logoFallback').classList.remove('hidden');el('logoFallback').textContent=(b.title||'SP').split(' ').map(x=>x[0]).slice(0,2).join('').toUpperCase()}}
    function renderHome(){applyBranding();const home=state.config.home;el('homeStats').innerHTML=home.stats.map(s=>`<div class="stat"><div class="num">${esc(s.num)}</div><div class="lbl">${esc(s.label)}</div></div>`).join('');el('homeFeatureChips').innerHTML=home.features.map(f=>`<span class="navchip">${esc(f)}</span>`).join('');el('homeCategories').innerHTML=home.categories.map(c=>`<div class="category"><h4>${esc(c.title)}</h4><p>${esc(c.desc)}</p><span class="count">${esc(c.count)}</span></div>`).join('');el('homePosts').innerHTML=home.posts.map(p=>`<div class="post"><h4>${esc(p.title)}</h4><p>${esc(p.body)}</p></div>`).join('');el('homeFaq').innerHTML=home.faq.map(item=>`<details><summary>${esc(item.q)}</summary><div class="body">${esc(item.a)}</div></details>`).join('');el('homeGuide').innerHTML=home.guide.replaceAll('\n','<br>');el('homeStatus').innerHTML=[`<span class="badge">${state.questions.length} soal tersimpan</span>`,`<span class="badge">${state.results.length} hasil direkap</span>`].join('')}
    
    /* LOGIN & ROLES */
    function openLogin(){el('loginOverlay').classList.add('show');el('adminEmail').value='';el('adminPassword').value='';setTimeout(()=>el('adminEmail').focus(),100)}
    function closeLogin(){el('loginOverlay').classList.remove('show')}
    function doLogin(){const email=el('adminEmail').value.trim();const password=el('adminPassword').value;const found=ADMIN_CREDENTIALS.find(a=>a.email===email&&a.password===password);if(!found){toast('Login gagal. Cek email dan password.');return}state.admin={email:found.email,role:found.role,label:found.label};saveAll();closeLogin();toast(`Masuk sebagai ${found.label}`);if(found.role==='superadmin'){showPage('super')}else{showPage('admin')}}
    function requireSuper(){if(state.admin?.role!=='superadmin'){toast('Hanya super admin yang bisa melakukan aksi ini.');return false}return true}
    
    function renderTabs(){document.querySelectorAll('#pageAdmin .tab').forEach(b=>b.classList.toggle('active',b.dataset.tab===state.adminTab));el('adminResultsTab').classList.toggle('hidden',state.adminTab!=='results');el('adminSettingsTab').classList.toggle('hidden',state.adminTab!=='settings')}
