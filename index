    const state={page:'home',admin:null,questions:[],results:[],draftEmail:'',studentIdentity:{},testIndex:0,answers:{},editingQuestionId:null,pendingImageData:null,config:loadJson(STORAGE_KEYS.settings,DEFAULT_CONFIG)};
